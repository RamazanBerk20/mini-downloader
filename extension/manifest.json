{
  "manifest_version": 3,
  "name": "Mini Downloader Connector",
  "version": "0.1.0",
  "description": "Catch downloads in Firefox and hand them to Mini Downloader.",
  "browser_specific_settings": {
    "gecko": {
      "id": "minidownloader@ramazan.dev",
      "strict_min_version": "128.0"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "downloads",
    "webRequest",
    "webRequestBlocking",
    "cookies",
    "contextMenus",
    "menus",
    "nativeMessaging",
    "notifications",
    "storage",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Download with Mini Downloader",
    "default_icon": { "48": "icons/48.png", "96": "icons/96.png" }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": { "48": "icons/48.png", "96": "icons/96.png" }
}
