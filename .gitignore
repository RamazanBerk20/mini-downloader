# Rust
/target
apps/desktop/src-tauri/target
**/*.rs.bk

# Node / frontend
node_modules
dist
apps/desktop/dist
.pnpm-store

# Tauri
apps/desktop/src-tauri/gen

# Staged sidecar binaries (fetched by scripts/stage-sidecars.sh)
apps/desktop/src-tauri/binaries/*
!apps/desktop/src-tauri/binaries/.gitkeep

# Bundles / artifacts
*.AppImage
*.deb
*.rpm
*.xpi

# Extension build
extension/web-ext-artifacts

# Env / local
.env
.env.local
*.log

# Per-browser extension build output
dist-ext

# Chrome extension signing key (secret)
packaging/chrome-extension-key.pem
packaging/chrome-key.b64

# AUR local build artifacts (updpkgsums/makepkg leave these in the pkg dirs)
packaging/aur/*/src/
packaging/aur/*/pkg/
packaging/aur/*/*.tar.gz
packaging/aur/*/*.pkg.tar.zst
