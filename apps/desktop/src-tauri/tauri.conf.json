{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Linux Download Manager",
  "version": "0.1.0",
  "identifier": "io.ldm.app",
  "build": {
    "beforeDevCommand": "./node_modules/.bin/vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "./node_modules/.bin/vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Linux Download Manager",
        "width": 1000,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["magnet", "ldm"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "category": "Network",
    "shortDescription": "IDM/JDownloader-style download manager",
    "longDescription": "A multi-connection download manager wrapping aria2, with a Firefox extension for capturing downloads, yt-dlp video grabbing, torrents, link grabber, scheduler and category auto-organize.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["aria2", "ffmpeg"],
        "recommends": ["yt-dlp"],
        "files": {
          "/usr/bin/ldm-native-host": "../../../target/release/ldm-native-host"
        },
        "postInstallScript": "scripts/postinstall.sh",
        "postRemoveScript": "scripts/postremove.sh"
      },
      "rpm": {
        "depends": ["aria2", "ffmpeg"],
        "files": {
          "/usr/bin/ldm-native-host": "../../../target/release/ldm-native-host"
        },
        "postInstallScript": "scripts/postinstall.sh",
        "postRemoveScript": "scripts/postremove.sh"
      }
    }
  }
}
