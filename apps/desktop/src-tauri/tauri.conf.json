{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mini Downloader",
  "version": "1.1.0",
  "identifier": "io.minidownloader.app",
  "build": {
    "beforeDevCommand": "node node_modules/vite/bin/vite.js",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node node_modules/vite/bin/vite.js build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mini Downloader",
        "width": 1000,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["magnet", "minidownloader"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "category": "Utility",
    "shortDescription": "IDM/JDownloader-style download manager",
    "longDescription": "A multi-connection download manager wrapping aria2, with a Firefox extension for capturing downloads, yt-dlp video grabbing, torrents, link grabber, scheduler and category auto-organize.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["aria2", "ffmpeg"],
        "recommends": ["yt-dlp"],
        "section": "net",
        "files": {
          "/usr/bin/minidl-native-host": "../../../target/release/minidl-native-host"
        },
        "postInstallScript": "scripts/postinstall.sh",
        "postRemoveScript": "scripts/postremove.sh"
      },
      "rpm": {
        "depends": ["aria2", "ffmpeg"],
        "files": {
          "/usr/bin/minidl-native-host": "../../../target/release/minidl-native-host"
        },
        "postInstallScript": "scripts/postinstall.sh",
        "postRemoveScript": "scripts/postremove.sh"
      }
    }
  }
}
